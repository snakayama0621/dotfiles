{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/scripts/deny-check.sh\"",
            "timeout": 30,
            "statusMessage": "Checking Bash command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/scripts/format-edited-files.sh\"",
            "timeout": 120,
            "statusMessage": "Formatting edited files"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/scripts/completion-notification.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
