# ============================================================================
# Git ローカル設定ファイル（環境固有）
# ============================================================================
# このファイルは .gitconfig.local にコピーして使用してください。
# .gitconfig.local は .gitignore で除外されているため、git追跡されません。
#
# 使用方法:
#   cp .gitconfig.local.example .gitconfig.local
#   # その後、name と email を自分の情報に書き換えてください

[user]
    name = Your Name
    email = your@email.com
